# Plantilla de archivo de entorno para /etc/default/mi-app
# Define variables usadas por el unit file

# destinatarios para el script (coma-separados)
RECIPIENTS="admin@example.com"

# Opcional: parámetros SMTP si el script los usa
SMTP_SERVER="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="secreto"

# Ruta al virtualenv (ajusta si es necesario)
VENV_PATH="/opt/mi-app/venv"

# Otras variables de configuración específicas de la app
# APP_CONFIG="/etc/mi-app/config.yml"
